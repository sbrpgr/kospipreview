# ============================================================
# 로컬 개발 환경 — DATA_BASE_URL을 설정하지 않으면
# 파일 시스템(../data/*.json)에서 직접 읽습니다.
# ============================================================

# 배포 환경 (Vercel 등)에서는 아래 주석을 해제하고 실제 값으로 변경하세요.
# DATA_BASE_URL=https://raw.githubusercontent.com/{GitHub_사용자명}/{레포이름}/main/data

# 실제 서비스 도메인 (sitemap, robots에 사용)
# NEXT_PUBLIC_SITE_URL=https://your-domain.com

# Google Search Console 메타 검증 토큰 (선택)
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=your_google_verification_token
